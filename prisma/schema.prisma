generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Politician {
  id                String              @id @default(cuid())
  name              String
  initials          String
  party             String
  level             String
  country           String
  jurisdiction      String
  role              String
  since             Int
  bio               String?
  imageUrl          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  birthYear         Int?
  estimatedNetWorth Float?
  firstElectedYear  Int?
  prePoliticsCareer String?
  barnacleScores    BarnacleScore[]
  contributions     DonorContribution[]
  scores            IntegrityScore[]
  statements        Statement[]
  votes             Vote[]
}

model Vote {
  id           String                   @id @default(cuid())
  politicianId String
  bill         String
  billId       String?
  issue        String
  vote         String
  date         DateTime
  description  String
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  politician   Politician               @relation(fields: [politicianId], references: [id])
  alignments   VoteStatementAlignment[]
}

model Statement {
  id           String                   @id @default(cuid())
  politicianId String
  content      String
  issue        String
  source       String?
  date         DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  politician   Politician               @relation(fields: [politicianId], references: [id])
  alignments   VoteStatementAlignment[]
}

model VoteStatementAlignment {
  id          String    @id @default(cuid())
  voteId      String
  statementId String
  aligned     Boolean
  explanation String
  createdAt   DateTime  @default(now())
  statement   Statement @relation(fields: [statementId], references: [id])
  vote        Vote      @relation(fields: [voteId], references: [id])
}

model Donor {
  id            String              @id @default(cuid())
  name          String
  industry      String
  type          String
  createdAt     DateTime            @default(now())
  contributions DonorContribution[]
}

model DonorContribution {
  id           String     @id @default(cuid())
  donorId      String
  politicianId String
  amount       Float
  year         Int
  cycle        String?
  createdAt    DateTime   @default(now())
  donor        Donor      @relation(fields: [donorId], references: [id])
  politician   Politician @relation(fields: [politicianId], references: [id])
}

model IntegrityScore {
  id             String     @id @default(cuid())
  politicianId   String
  integrityScore Float
  sleazeScore    Float
  alignmentRate  Float
  donorInfluence Float
  flipFrequency  Float
  partySpectrum  Float
  integrityAxis  Float
  calculatedAt   DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  politician     Politician @relation(fields: [politicianId], references: [id])
}

model BarnacleScore {
  id                    String     @id @default(cuid())
  politicianId          String
  barnacleScore         Float
  citizenStatesmanScore Float
  tenureYears           Int
  privateCareerYears    Int
  citizenRatio          Float
  tenureScore           Float
  citizenRatioScore     Float
  wealthGapScore        Float
  revolvingDoorScore    Float
  entrenchmentScore     Float
  aiNarrative           String?
  calculatedAt          DateTime   @default(now())
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  politician            Politician @relation(fields: [politicianId], references: [id])
}
